{
  "name": "react-material-web",
  "version": "0.1.0",
  "description": "React components wrapping Google's @material/web (Material Design 3)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
